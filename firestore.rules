rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hàm kiểm tra xem User có phải là Admin không
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Kiểm tra xem user hiện tại có phải là Super Admin không
    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    // 1. Sản phẩm (products)
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Khách hàng chỉ được cập nhật tồn kho và số lượng bán
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'sold']) &&
        // Đảm bảo dữ liệu mới vẫn hợp lệ (không bị âm)
        request.resource.data.stock is int &&
        request.resource.data.stock >= 0 &&
        request.resource.data.sold is int
      );
    }
    
    // 2. Danh sách Admin
    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow list: if isSuperAdmin(); // Chỉ Super Admin mới được xem danh sách admin
      allow write: if isSuperAdmin(); // Chỉ Super Admin mới được quản lý danh sách Admin
    }

    // 3. Giỏ hàng & Yêu thích
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /favorites/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Thông tin người dùng (users)
    match /users/{userId} {
      // Cho phép đọc nếu là chính chủ, admin, hoặc là tài khoản ghost (để tìm kiếm khi login)
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId) || resource.data.isGhost == true;
      // Cho phép tạo ghost account khi đặt hàng hoặc tạo tài khoản mới
      allow create: if true;
      allow update: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId); // Super Admin hoặc chính chủ
      allow delete: if isSuperAdmin() || (request.auth != null && resource.data.isGhost == true); // Super Admin hoặc user ghost tự xóa
    }

    // 5. Đơn hàng (orders)
    match /orders/{orderId} {
      allow create: if 
        // Kiểm tra dữ liệu đơn hàng cơ bản khi tạo
        request.resource.data.status == "Đang xử lý" &&
        request.resource.data.totalAmount > 0 &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.orderDate == request.time; // Ép dùng thời gian server
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      // Admin sửa mọi thứ, User chỉ được Hủy khi đang xử lý
      allow update: if isAdmin() || 
        (request.auth != null && request.auth.uid == resource.data.userId && 
         resource.data.status == "Đang xử lý" && request.resource.data.status == "Đã hủy" && // Chỉ cho phép chuyển từ "Đang xử lý" sang "Đã hủy"
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'canceledBy', 'canceledAt'])); // Chỉ được sửa các trường này
    }

    // 6. Cấu hình hệ thống (Danh mục động)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin(); // Chỉ Super Admin mới được sửa cài đặt hệ thống
    }

    // 7. Mã giảm giá (coupons)
    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin(); // Chỉ Super Admin mới được tạo/xóa coupon
      allow update: if isSuperAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']); // Super Admin hoặc update usedCount
    }

    // 8. Đánh giá (reviews)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin() || (request.auth != null && resource.data.userId == request.auth.uid); // Super Admin hoặc chính chủ
    }

    // 9. Tin tức (news)
    match /news/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}


service firebase.storage {
  match /b/{bucket}/o {
    // Hàm kiểm tra admin bên Storage
    function isAdmin() { // Kiểm tra xem user có tồn tại trong collection admins không
      return request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
    
    // Kiểm tra xem user hiện tại có phải là Super Admin không
    function isSuperAdmin() {
      return isAdmin() && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin(); 
    }

    // 4. Ảnh Banner (banners) - Cho phép quản trị viên thay đổi banner trang chủ
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Ảnh Danh mục (categories) - Cần thiết cho tính năng mới
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin(); // Chỉ Super Admin mới được quản lý ảnh danh mục
    }

    // 5. Ảnh Tin tức (news)
    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /reviews/{productId}/{allPaths=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if isSuperAdmin(); // Chỉ Super Admin mới được xóa ảnh review
    }
  }
}

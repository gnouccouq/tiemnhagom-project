rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hàm kiểm tra xem User có phải là Admin không
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. Sản phẩm (products)
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Cho phép Admin update hoặc khách update stock/sold
      allow update: if isAdmin() || 
        (request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'sold']));
    }
    
    // 2. Danh sách Admin
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Chỉ chỉnh sửa tay trên Firebase Console
    }

    // 3. Giỏ hàng & Yêu thích
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /favorites/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Thông tin người dùng (users)
    match /users/{userId} {
      // Cho phép đọc nếu là chính chủ, admin, hoặc là tài khoản ghost (để tìm kiếm khi login)
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId) || resource.data.isGhost == true;
      // Cho phép ghi/xóa nếu là chính chủ, admin, hoặc thao tác trên tài khoản ghost
      allow write, delete: if isAdmin() || (request.auth != null && request.auth.uid == userId) || resource.data.isGhost == true;
      allow create: if true; // Cho phép tạo ghost account khi đặt hàng
    }

    // 5. Đơn hàng (orders)
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      // Admin sửa mọi thứ, User chỉ được Hủy khi đang xử lý
      allow update: if isAdmin() || 
        (request.auth != null && request.auth.uid == resource.data.userId && 
         resource.data.status == "Đang xử lý" && request.resource.data.status == "Đã hủy");
    }

    // 6. Mã giảm giá (coupons)
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Đánh giá (reviews)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}


service firebase.storage {
  match /b/{bucket}/o {
    // Hàm kiểm tra admin bên Storage
    function isAdmin() {
      return request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
    
    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /reviews/{productId}/{allPaths=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
  }
}
